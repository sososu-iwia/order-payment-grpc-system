# Order Service — copy to .env and fill in values

PostgreSQL connection string
ORDER_DB_DSN=postgres://postgres:postgres@localhost:5433/order_db?sslmode=disable

# HTTP REST port (for end-users / curl)
PORT=8081

# gRPC address of the Payment Service (host:port)
PAYMENT_GRPC_ADDR=localhost:50051

# gRPC port for SubscribeToOrderUpdates streaming
GRPC_PORT=50052
